# Copy to .env.local and fill in your values. Never commit .env.local.

# RPC URLs (Helius example - replace with your API key)
NEXT_PUBLIC_MAINNET_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Jupiter API key (for mainnet perps)
NEXT_PUBLIC_JUPITER_API_KEY=your_jupiter_api_key
